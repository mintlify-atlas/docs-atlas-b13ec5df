  "keyFeatures": [
    "Role-based dashboards for Administrators, Coordinators, and Students",
    "Class scheduling management with multi-location and court support",
    "Student enrollment and training level management",
    "Attendance tracking with present, absent, late, and excused states",
    "Payment and accounts-receivable management with discount/benefit support",
    "Class rescheduling and recovery session management",
    "Publications and news feed for students",
    "Guest pass management",
    "Injury tracking and recovery management",
    "Excel report exports for admins"
  ],
